# LiveKit (Person 1 — real calls)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AWS Bedrock — Nova Sonic 2 (enable model in Bedrock console)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Moss tactic retrieval (Person 3)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=scam-tactics
MOSS_MODEL_ID=moss-minilm

# Dashboard
DASHBOARD_PORT=8080
DASHBOARD_INGEST_URL=http://localhost:8080/ingest

# Twilio SMS summary (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1XXXXXXXXXX
NOTIFY_PHONE_NUMBER=+1XXXXXXXXXX
# Send when scam_score reaches this (0.0-1.0) or on hangup if still elevated
NOTIFY_SCORE_THRESHOLD=0.66
# End the call when score reaches this (defaults to NOTIFY_SCORE_THRESHOLD)
HANGUP_SCORE_THRESHOLD=0.66
