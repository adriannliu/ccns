# LiveKit (Person 1 — real calls)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AWS Bedrock — Nova Sonic 2 (enable model in Bedrock console)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Moss tactic retrieval (Person 3)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=scam-tactics
MOSS_MODEL_ID=moss-minilm
# Scam score tuning (semantic-relevance driven, not keyword-gated).
# Retrieval score at/below this = tactic is irrelevant (no score contribution).
MOSS_SEM_THRESHOLD=0.45
# Retrieval score at/above this = full semantic match. Ramp runs between the two;
# raise the ceiling if your index returns high scores broadly (fewer false positives).
MOSS_SEM_FULL_RELEVANCE=0.75
# Max extra confidence when the caller also uses verbatim red-flag phrasing.
MOSS_KEYWORD_BONUS=0.15
# Max the score can rise from a SINGLE caller turn of passive retrieval. Keeps one
# topic mention (e.g. "gift card") out of the critical band; evidence then
# accumulates across turns. Lower = more conservative, slower to escalate.
MOSS_SEM_TURN_CAP=0.45

# Dashboard
DASHBOARD_PORT=8080
DASHBOARD_INGEST_URL=http://localhost:8080/ingest

# Console summary when scam_score is elevated or call ends suspiciously
NOTIFY_SCORE_THRESHOLD=0.66
# Hang up after score stays at/above this for N caller turns (back-and-forth)
HANGUP_SCORE_THRESHOLD=0.66
HANGUP_EXCHANGES_REQUIRED=2
# Caller turns that must elapse before ANY auto hang-up (even a confirmed-tactic /
# confident-signal trigger). Guarantees the caller gets a few chances to justify
# themselves before detection alone ends the call. Set 0 to disable the grace period.
HANGUP_MIN_CALLER_TURNS=2
DECISION_MAX_EXCHANGES=2

# SIP cold transfer on PASS (SIP REFER via Twilio trunk)
RESIDENT_PHONE=+1XXXXXXXXXX
# Required for Twilio PSTN transfer in most setups (Trunk → Termination SIP URI)
TWILIO_PSTN_DOMAIN=mytrunk.pstn.twilio.com
# TRANSFER_ENABLED=false
